{
  "name": "cc-bridge-desktop",
  "productName": "CC Bridge",
  "version": "0.1.5",
  "description": "CC Bridge 桌面应用壳。",
  "author": {
    "name": "kongran Ling",
    "email": "kongran@example.com"
  },
  "private": true,
  "main": "desktop/electron/main.cjs",
  "scripts": {
    "desktop:dev": "electron .",
    "desktop:pack": "electron-builder --dir -c desktop/electron-builder.config.cjs",
    "desktop:dist": "electron-builder -c desktop/electron-builder.config.cjs",
    "desktop:dist:win": "electron-builder --win nsis -c desktop/electron-builder.config.cjs",
    "desktop:dist:mac": "electron-builder --mac dmg zip -c desktop/electron-builder.config.cjs",
    "desktop:dist:linux": "electron-builder --linux AppImage deb -c desktop/electron-builder.config.cjs",
    "package:desktop": "powershell -ExecutionPolicy Bypass -File scripts/package-desktop.ps1",
    "package:desktop:pack": "powershell -ExecutionPolicy Bypass -File scripts/package-desktop.ps1 -Target pack",
    "package:desktop:release": "powershell -ExecutionPolicy Bypass -File scripts/package-desktop.ps1 -Release"
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  },
  "devDependencies": {
    "electron": "40.10.2",
    "electron-builder": "26.8.1"
  }
}
