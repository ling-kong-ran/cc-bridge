{
  "name": "cc-bridge-desktop",
  "productName": "CC Bridge",
  "version": "0.1.5",
  "description": "CC Bridge 桌面应用壳。",
  "author": {
    "name": "kongran Ling",
    "email": "kongran@example.com"
  },
  "private": true,
  "main": "desktop/electron/main.cjs",
  "scripts": {
    "desktop:dev": "electron .",
    "desktop:pack": "electron-builder --dir",
    "desktop:dist": "electron-builder",
    "desktop:dist:win": "electron-builder --win nsis",
    "desktop:dist:mac": "electron-builder --mac dmg zip",
    "desktop:dist:linux": "electron-builder --linux AppImage deb",
    "package:desktop": "powershell -ExecutionPolicy Bypass -File scripts/package-desktop.ps1",
    "package:desktop:pack": "powershell -ExecutionPolicy Bypass -File scripts/package-desktop.ps1 -Target pack",
    "package:desktop:release": "powershell -ExecutionPolicy Bypass -File scripts/package-desktop.ps1 -Release"
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  },
  "devDependencies": {
    "electron": "40.10.2",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "local.cc-bridge.desktop",
    "productName": "CC Bridge",
    "icon": "desktop/assets/icon",
    "artifactName": "CC-Bridge-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "ling-kong-ran",
        "repo": "cc-bridge"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/electron/**",
      "desktop/assets/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "cc-bridge",
        "filter": [
          "*.py",
          "backend/**",
          "bootstrap/**",
          "custom_tools/**",
          "docs/**",
          "static/**",
          "requirements.txt"
        ]
      }
    ],
    "asar": true,
    "win": {
      "icon": "desktop/assets/icon.ico",
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "icon": "desktop/assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "desktop/assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "CC Bridge",
      "uninstallDisplayName": "CC Bridge"
    }
  }
}
