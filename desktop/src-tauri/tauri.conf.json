{
  "productName": "CC-GUI",
  "version": "0.1.0",
  "identifier": "com.ccgui.desktop",
  "build": {
    "frontendDist": "../../static",
    "devUrl": "http://127.0.0.1:17878",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/server/server.exe"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "PLACEHOLDER",
      "endpoints": [
        "https://github.com/ling-kong-ran/cc-gui/releases/latest/download/latest.json"
      ]
    }
  }
}
